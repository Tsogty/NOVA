<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Schedule Manager</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI, sans-serif;
}

body{
background:url('https://i.pinimg.com/1200x/92/3e/c4/923ec4b2a3e78209add40869683fcdf4.jpg') no-repeat center center/cover;
color:#e0e7ff;
position:relative;
}

/* 🌌 overlay */
body::before{
content:"";
position:fixed;
inset:0;
backdrop-filter:blur(10px);
background:rgba(20,20,60,0.55);
z-index:-1;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 60px;
background:rgba(20,20,60,0.6);
backdrop-filter:blur(14px);
border-bottom:1px solid rgba(255,255,255,0.08);
}

/* 🔥 LOGO UPGRADE */
.logo{
height: 10;
font-weight: 2;
width: 2;
}

/* NAV LINKS */

nav ul{
display:flex;
list-style:none;
gap:30px;
align-items:center;
}

nav a{
text-decoration:none;
color:#c7d2fe;
font-weight:500;
transition:0.3s;
}

nav a:hover{
color:white;
}

/* dropdown */
.dropdown{
position:relative;
}

.dropdown-menu{
display:none;
position:absolute;
top:120%;
left:0;
background:rgba(30,30,70,0.9);
backdrop-filter:blur(14px);
border-radius:14px;
padding:10px 0;
width:180px;
box-shadow:0 10px 30px rgba(0,0,0,0.3);
}

.dropdown-menu a{
display:block;
padding:10px 16px;
color:#c7d2fe;
}

.dropdown-menu a:hover{
background:rgba(99,102,241,0.2);
}

.dropdown:hover .dropdown-menu{
display:block;
}

/* AUTH */

.auth button{
padding:10px 18px;
border-radius:12px;
border:none;
cursor:pointer;
font-weight:600;
transition:0.3s;
}

.login{
background:rgba(255,255,255,0.1);
color:#e0e7ff;
}

.signup{
background:linear-gradient(90deg,#60a5fa,#8b5cf6);
color:white;
box-shadow:0 0 20px rgba(99,102,241,0.3);
}

.signup:hover{
transform:scale(1.05);
}

/* HERO */

.hero{
text-align:center;
padding:100px 20px;
}

.hero h1{
font-size:56px;
margin-bottom:15px;
letter-spacing:1px;
}

.hero p{
color:#c7d2fe;
margin-bottom:30px;
font-size:18px;
}

.hero button{
background:linear-gradient(90deg,#60a5fa,#8b5cf6);
color:white;
border:none;
padding:16px 35px;
border-radius:16px;
font-size:16px;
cursor:pointer;
box-shadow:0 10px 30px rgba(0,0,0,0.3);
transition:.3s;
}

.hero button:hover{
transform:translateY(-4px) scale(1.03);
}

/* FEATURES */

.features{
display:flex;
justify-content:center;
gap:35px;
padding:40px;
flex-wrap:wrap;
}

.card{
width:260px;
padding:30px;
border-radius:20px;
background:rgba(30,30,70,0.6);
backdrop-filter:blur(14px);
color:#e0e7ff;
box-shadow:0 15px 40px rgba(0,0,0,0.4);
transition:.3s;
border:1px solid rgba(255,255,255,0.08);
position:relative;
overflow:hidden;
}

.card::before{
content:"";
position:absolute;
inset:0;
background:linear-gradient(120deg,transparent,rgba(255,255,255,0.1),transparent);
opacity:0;
transition:.4s;
}

.card:hover::before{
opacity:1;
}

.card:hover{
transform:translateY(-8px) scale(1.02);
}

.card h3{
margin-bottom:10px;
}

/* SCHEDULE */

.schedule{
max-width:800px;
margin:60px auto;
background:rgba(30,30,70,0.7);
border-radius:22px;
padding:40px;
box-shadow:0 20px 50px rgba(0,0,0,0.5);
backdrop-filter:blur(14px);
border:1px solid rgba(255,255,255,0.08);
}

.schedule h2{
margin-bottom:25px;
font-size:24px;
}

.item{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 0;
border-bottom:1px solid rgba(255,255,255,0.08);
transition:0.3s;
}

.item:hover{
background:rgba(255,255,255,0.03);
border-radius:10px;
padding-left:10px;
}

.time{
font-size:14px;
color:#a5b4fc;
}

.subject{
font-weight:600;
}

.dot{
width:6px;
height:35px;
border-radius:10px;
margin-right:12px;
}

.row{
display:flex;
align-items:center;
}

.math{background:#3b82f6;}
.eng{background:#a855f7;}
.sci{background:#22c55e;}
.study{background:#f43f5e;}

.check{
cursor:pointer;
color:#6b7280;
font-size:18px;
transition:0.3s;
}

.done{
color:#22c55e;
}

</style>
</head>

<body>

<nav>
<div class="logo">Nova</div>

<ul>
<li><a href="home.html">Home</a></li>
<li><a href="quiz.html">Quiz Generator</a></li>
<li><a href="Ai.html">AI Assistant</a></li>
<li><a href="calendar.html">Schedule Manager</a></li>

<li class="dropdown">
<a href="#">Grades ▾</a>
<div class="dropdown-menu">
<a href="#">Primary School</a>
<a href="#">Middle School</a>
<a href="#">High School</a>
</div>
</li>

</ul>

<div class="auth">
<button class="login"><a href="Login.html">Log In</a></button>
<button class="signup"><a href="sign up.html">Sign Up</a></button>
</div>

</nav>

<section class="hero">

<h1>Schedule Manager</h1>

<p>Organize your classes, assignments, and study time in one beautiful interface.</p>

<button><a href="calendar1.html">Create Your Schedule</a></button>

</section>

<section class="features">

<div class="card">
<h3>Time Blocking</h3>
<p>Allocate dedicated time slots for each subject and activity.</p>
</div>

<div class="card">
<h3>Assignment Tracking</h3>
<p>Never miss deadlines with reminders and notifications.</p>
</div>

<div class="card">
<h3>Progress Monitoring</h3>
<p>Track completed tasks and visualize productivity.</p>
</div>

</section>

<section class="schedule">

<h2>Today's Schedule</h2>

<div class="item">
<div class="row">
<div class="dot math"></div>
<div>
<div class="time">9:00 AM</div>
<div class="subject">Mathematics</div>
</div>
</div>
<div class="check" onclick="toggle(this)">✔</div>
</div>

<div class="item">
<div class="row">
<div class="dot eng"></div>
<div>
<div class="time">10:30 AM</div>
<div class="subject">English Literature</div>
</div>
</div>
<div class="check" onclick="toggle(this)">✔</div>
</div>

<div class="item">
<div class="row">
<div class="dot sci"></div>
<div>
<div class="time">1:00 PM</div>
<div class="subject">Science Lab</div>
</div>
</div>
<div class="check" onclick="toggle(this)">✔</div>
</div>

<div class="item">
<div class="row">
<div class="dot study"></div>
<div>
<div class="time">3:00 PM</div>
<div class="subject">Study Time</div>
</div>
</div>
<div class="check" onclick="toggle(this)">✔</div>
</div>

</section>

<script>
function toggle(el){
el.classList.toggle("done")
}
</script>

</body>
</html>
