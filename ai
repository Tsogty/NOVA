    background: url('https://i.pinimg.com/736x/5c/6a/7c/5c6a7c79c2518f22329bba53118583f6.jpg') no-repeat center center/cover;
    position: relative;
    color: #dbeafe;
  }

  /* 🔧 LESS BLUR */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    backdrop-filter: blur(6px);
    background: rgba(5, 10, 25, 0.7);
    z-index: -1;
  }

  /* 🧊 NAVY GLASS */
  .glass {
    background: rgba(10, 20, 40, 0.65);
    backdrop-filter: blur(10px);
